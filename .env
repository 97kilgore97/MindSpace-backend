DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────
# Development: uses SQLite (no setup needed — just run migrate)
# Production: switch to PostgreSQL by uncommenting below
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/calmconnect

# ── CORS (React frontend) ────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# ── JWT ───────────────────────────────────────────────────
# Access token expires in 1 hour, refresh in 7 days
# These are handled in settings.py via SIMPLE_JWT — no change needed here

# ── Redis (WebSockets via Django Channels) ────────────────
# Development: install Redis locally → brew install redis (Mac) or apt install redis (Linux)
# Then run: redis-server
REDIS_URL=redis://localhost:6379

# If you don't want to install Redis during early dev, open settings.py
# and swap the CHANNEL_LAYERS backend to InMemoryChannelLayer (no persistence):
# 'BACKEND': 'channels.layers.InMemoryChannelLayer'

